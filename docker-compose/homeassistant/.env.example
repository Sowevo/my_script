# Home Assistant + micam stack env
TZ=Asia/Shanghai

# Miloco
MILOCO_PORT=8000
MILOCO_LOG_LEVEL=warning
MILOCO_BASE_URL=https://miloco:8000
MILOCO_HOST_IP=host-gateway

# micam camera 1 (required)
MILOCO_PASSWORD=
CAMERA_ID=
RTSP_URL=rtsp://127.0.0.1:8554/cam1
VIDEO_CODEC=hevc
STREAM_CHANNEL=0

# micam camera 2 (optional)
CAMERA_2_ID=
CAMERA_2_RTSP_URL=rtsp://127.0.0.1:8554/cam2
